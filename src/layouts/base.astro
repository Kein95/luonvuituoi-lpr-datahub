---
import { ClientRouter } from "astro:transitions";
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "LPR Dataset Hub",
  description = "ALL-IN-ONE gateway for License Plate Recognition datasets. Discover, compare, and access 16+ datasets across 10+ countries.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <ClientRouter />
    <script is:inline>
      (function(){
        var t = localStorage.getItem("theme");
        var d = t === "dark" || (t !== "light" && window.matchMedia("(prefers-color-scheme: dark)").matches);
        document.documentElement.classList.toggle("dark", d);
      })();
    </script>
    <!-- Vercel Analytics (free) -->
    <script defer src="/_vercel/insights/script.js"></script>
    <!-- Vercel Speed Insights (free) -->
    <script defer src="/_vercel/speed-insights/script.js"></script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 border-b border-[rgb(var(--card-border))]/50 bg-[rgb(var(--bg))]/70 backdrop-blur-xl backdrop-saturate-150">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">
          <a href="/" class="flex items-center gap-2.5 font-bold text-lg group" data-astro-prefetch>
            <span class="text-xl">🚗</span>
            <span class="tracking-tight">LPR Dataset <span class="gradient-text">Hub</span></span>
          </a>
          <div class="flex items-center gap-1">
            <a href="/" class="nav-link px-3 py-1.5 rounded-lg text-sm font-medium text-[rgb(var(--muted))] hover:text-[rgb(var(--fg))] hover:bg-[rgb(var(--card-hover))] transition-all" data-astro-prefetch>
              Catalog
            </a>
            <a href="/leaderboard" class="nav-link px-3 py-1.5 rounded-lg text-sm font-medium text-[rgb(var(--muted))] hover:text-[rgb(var(--fg))] hover:bg-[rgb(var(--card-hover))] transition-all" data-astro-prefetch>
              Leaderboard
            </a>
            <a
              href="https://github.com/Kein95/luonvuituoi-lpr-datahub"
              target="_blank"
              rel="noopener"
              class="ml-2 p-2 rounded-lg text-[rgb(var(--muted))] hover:text-[rgb(var(--fg))] hover:bg-[rgb(var(--card-hover))] transition-all"
              aria-label="GitHub"
            >
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
            <div class="relative" id="theme-wrapper">
              <button
                id="theme-toggle"
                class="p-2 rounded-lg text-[rgb(var(--muted))] hover:text-[rgb(var(--fg))] hover:bg-[rgb(var(--card-hover))] transition-all"
                aria-label="Toggle theme"
              >
                <svg id="icon-light" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <circle cx="12" cy="12" r="5" /><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
                </svg>
                <svg id="icon-dark" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
                </svg>
                <svg id="icon-auto" class="w-5 h-5 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                  <rect x="2" y="3" width="20" height="14" rx="2" ry="2" /><path d="M8 21h8M12 17v4" />
                </svg>
              </button>
              <!-- Dropdown -->
              <div id="theme-menu" class="hidden absolute right-0 top-full mt-2 w-36 rounded-xl border border-[rgb(var(--card-border))] bg-[rgb(var(--card))] shadow-lg py-1 z-50">
                <button data-theme="light" class="theme-option w-full px-3 py-2 text-left text-sm flex items-center gap-2 hover:bg-[rgb(var(--card-hover))] transition-colors">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="5" /><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" /></svg>
                  Light
                </button>
                <button data-theme="dark" class="theme-option w-full px-3 py-2 text-left text-sm flex items-center gap-2 hover:bg-[rgb(var(--card-hover))] transition-colors">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" /></svg>
                  Dark
                </button>
                <button data-theme="auto" class="theme-option w-full px-3 py-2 text-left text-sm flex items-center gap-2 hover:bg-[rgb(var(--card-hover))] transition-colors">
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="2" y="3" width="20" height="14" rx="2" ry="2" /><path d="M8 21h8M12 17v4" /></svg>
                  Auto
                </button>
              </div>
            </div>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-[rgb(var(--card-border))]/50 py-8 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm text-[rgb(var(--muted))]">
        <p class="mb-3">
          Special thanks to the <a href="https://aivietnam.edu.vn/" target="_blank" rel="noopener" class="text-[rgb(var(--accent))] hover:underline font-medium">AI VIET NAM (AIO)</a> community
          and TA <a href="https://github.com/duongtruongbinh" target="_blank" rel="noopener" class="text-[rgb(var(--accent))] hover:underline font-medium">Truong-Binh Duong</a>
        </p>
        <p class="mb-4">
          <strong>LPR Dataset Hub</strong> &middot;
          By <a href="https://github.com/Kein95" target="_blank" rel="noopener" class="text-[rgb(var(--accent))] hover:underline font-medium">Kein</a> (AIO2024)
          &middot; <a href="mailto:htkien95@gmail.com" class="hover:text-[rgb(var(--accent))] transition-colors">htkien95@gmail.com</a>
        </p>
        <div class="flex flex-wrap justify-center gap-2">
          <a href="https://aivietnam.edu.vn/" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-[rgb(var(--card-border))] text-[rgb(var(--fg))] text-xs font-medium hover:border-[rgb(var(--accent))]/50 hover:text-[rgb(var(--accent))] transition-all">
            🎓 Learn AI
          </a>
          <a href="https://aioconquer.aivietnam.edu.vn/" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-[rgb(var(--card-border))] text-[rgb(var(--fg))] text-xs font-medium hover:border-[rgb(var(--accent))]/50 hover:text-[rgb(var(--accent))] transition-all">
            📝 Blog
          </a>
          <a href="https://www.facebook.com/aivietnam.edu.vn" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-[rgb(var(--card-border))] text-[rgb(var(--fg))] text-xs font-medium hover:border-[rgb(var(--accent))]/50 hover:text-[rgb(var(--accent))] transition-all">
            💬 Facebook
          </a>
          <a href="https://github.com/Kein95/luonvuituoi-lpr-datahub" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-[rgb(var(--accent))]/30 text-[rgb(var(--accent))] text-xs font-medium hover:bg-[rgb(var(--accent))]/10 transition-all">
            ⭐ Contribute via PR
          </a>
        </div>
      </div>
    </footer>

    <!-- Theme Toggle + Nav Active Script -->
    <script is:inline>
      /* Theme: dropdown select Light / Dark / Auto */
      function setupTheme() {
        var stored = localStorage.getItem("theme");
        var prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        var isDark = stored === "dark" || (stored !== "light" && prefersDark);
        document.documentElement.classList.toggle("dark", isDark);
        updateThemeIcon(stored);
        highlightActive(stored);

        // Toggle dropdown on button click
        var btn = document.getElementById("theme-toggle");
        var menu = document.getElementById("theme-menu");
        if (btn && menu) {
          btn.onclick = function(e) {
            e.stopPropagation();
            menu.classList.toggle("hidden");
          };
          // Close on click outside
          document.addEventListener("click", function() { menu.classList.add("hidden"); });
          menu.onclick = function(e) { e.stopPropagation(); };
        }

        // Option clicks
        document.querySelectorAll(".theme-option").forEach(function(opt) {
          opt.onclick = function() {
            var val = this.getAttribute("data-theme");
            if (val === "auto") localStorage.removeItem("theme");
            else localStorage.setItem("theme", val);
            var pref = window.matchMedia("(prefers-color-scheme: dark)").matches;
            var dark = val === "dark" || (val === "auto" && pref);
            document.documentElement.classList.toggle("dark", dark);
            updateThemeIcon(val === "auto" ? null : val);
            highlightActive(val === "auto" ? null : val);
            if (menu) menu.classList.add("hidden");
          };
        });
      }

      function updateThemeIcon(mode) {
        var il = document.getElementById("icon-light");
        var id = document.getElementById("icon-dark");
        var ia = document.getElementById("icon-auto");
        if (!il || !id || !ia) return;
        il.classList.add("hidden");
        id.classList.add("hidden");
        ia.classList.add("hidden");
        if (mode === "light") il.classList.remove("hidden");
        else if (mode === "dark") id.classList.remove("hidden");
        else ia.classList.remove("hidden");
      }

      function highlightActive(mode) {
        document.querySelectorAll(".theme-option").forEach(function(opt) {
          var val = opt.getAttribute("data-theme");
          var isActive = (val === "auto" && !mode) || val === mode;
          opt.classList.toggle("text-[rgb(var(--accent))]", isActive);
          opt.classList.toggle("font-semibold", isActive);
        });
      }

      function setActiveNav() {
        var path = window.location.pathname;
        document.querySelectorAll(".nav-link").forEach(function(link) {
          var href = link.getAttribute("href");
          var isActive = (href === "/" && path === "/") || (href !== "/" && path.startsWith(href));
          if (isActive) {
            link.classList.add("text-[rgb(var(--fg))]", "bg-[rgb(var(--card))]");
            link.classList.remove("text-[rgb(var(--muted))]");
          } else {
            link.classList.remove("text-[rgb(var(--fg))]", "bg-[rgb(var(--card))]");
            link.classList.add("text-[rgb(var(--muted))]");
          }
        });
      }

      setupTheme();
      setActiveNav();
      document.addEventListener("astro:after-swap", function() { setupTheme(); setActiveNav(); });
    </script>
  </body>
</html>
