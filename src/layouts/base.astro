---
import { ClientRouter } from "astro:transitions";
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "LPR Dataset Hub",
  description = "ALL-IN-ONE gateway for License Plate Recognition datasets. Discover, compare, and access 15+ datasets across 10+ countries.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <ClientRouter />
    <!-- Prevent theme flash: apply saved theme before paint -->
    <script is:inline>
      (function(){
        var t = localStorage.getItem("theme");
        var d = t === "dark" || (!t && window.matchMedia("(prefers-color-scheme: dark)").matches);
        document.documentElement.classList.toggle("dark", d);
      })();
    </script>
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 border-b border-[rgb(var(--card-border))] bg-[rgb(var(--bg))]/80 backdrop-blur-md">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <a href="/" class="flex items-center gap-2 font-semibold text-lg hover:text-[rgb(var(--accent))] transition-colors">
            <span class="text-xl">🚗</span>
            <span>LPR Dataset Hub</span>
          </a>
          <div class="flex items-center gap-4">
            <a href="/" class="text-sm font-medium text-[rgb(var(--muted))] hover:text-[rgb(var(--fg))] transition-colors">
              Catalog
            </a>
            <a href="/leaderboard" class="text-sm font-medium text-[rgb(var(--muted))] hover:text-[rgb(var(--fg))] transition-colors">
              Leaderboard
            </a>
            <a
              href="https://github.com/Kein95/luonvuituoi-lpr-datahub"
              target="_blank"
              rel="noopener"
              class="text-sm font-medium text-[rgb(var(--muted))] hover:text-[rgb(var(--fg))] transition-colors"
            >
              GitHub
            </a>
            <button
              id="theme-toggle"
              class="p-2 rounded-lg text-[rgb(var(--muted))] hover:text-[rgb(var(--fg))] hover:bg-[rgb(var(--card))] transition-colors"
              aria-label="Toggle theme"
            >
              <svg id="sun-icon" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="5" /><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
              </svg>
              <svg id="moon-icon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-[rgb(var(--card-border))] py-8 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm text-[rgb(var(--muted))]">
        <p class="mb-2">
          <strong>LPR Dataset Hub</strong> — ALL-IN-ONE gateway for License Plate Recognition research
        </p>
        <p class="mb-2">
          By <a href="https://github.com/Kein95" target="_blank" rel="noopener" class="text-[rgb(var(--accent))] hover:underline">Kein</a> (AIO2024)
          <span class="mx-1">·</span>
          Contact: <a href="mailto:htkien95@gmail.com" class="hover:text-[rgb(var(--accent))] transition-colors">htkien95@gmail.com</a>
        </p>
        <p class="mb-2">
          Special thanks to the <a href="https://aivietnam.edu.vn/" target="_blank" rel="noopener" class="text-[rgb(var(--accent))] hover:underline">AI VIET NAM (AIO)</a> community
          and TA <a href="https://github.com/duongtruongbinh" target="_blank" rel="noopener" class="text-[rgb(var(--accent))] hover:underline">Truong-Binh Duong</a>
        </p>
        <div class="flex flex-wrap justify-center gap-2 mt-3">
          <a href="https://aivietnam.edu.vn/" target="_blank" rel="noopener" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full border border-[rgb(var(--accent))] text-[rgb(var(--accent))] text-xs font-medium hover:bg-[rgb(var(--accent))]/10 transition-colors">
            🎓 Learn AI
          </a>
          <a href="https://aioconquer.aivietnam.edu.vn/" target="_blank" rel="noopener" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full border border-[rgb(var(--card-border))] text-[rgb(var(--fg))] text-xs font-medium hover:border-[rgb(var(--accent))] hover:text-[rgb(var(--accent))] transition-colors">
            📝 Blog
          </a>
          <a href="https://www.facebook.com/aivietnam.edu.vn" target="_blank" rel="noopener" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full border border-[rgb(var(--card-border))] text-[rgb(var(--fg))] text-xs font-medium hover:border-[rgb(var(--accent))] hover:text-[rgb(var(--accent))] transition-colors">
            💬 Facebook
          </a>
          <a href="https://github.com/Kein95/luonvuituoi-lpr-datahub" target="_blank" rel="noopener" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full border border-[rgb(var(--card-border))] text-[rgb(var(--fg))] text-xs font-medium hover:border-[rgb(var(--accent))] hover:text-[rgb(var(--accent))] transition-colors">
            ⭐ Contribute via PR
          </a>
        </div>
      </div>
    </footer>

    <!-- Theme Toggle Script -->
    <script is:inline>
      function setupTheme() {
        var stored = localStorage.getItem("theme");
        var isDark = stored === "dark" || (!stored && window.matchMedia("(prefers-color-scheme: dark)").matches);
        document.documentElement.classList.toggle("dark", isDark);
        var sun = document.getElementById("sun-icon");
        var moon = document.getElementById("moon-icon");
        if (sun) sun.classList.toggle("hidden", isDark);
        if (moon) moon.classList.toggle("hidden", !isDark);

        var btn = document.getElementById("theme-toggle");
        if (btn) {
          // Remove old listeners by cloning
          var newBtn = btn.cloneNode(true);
          btn.parentNode.replaceChild(newBtn, btn);
          newBtn.addEventListener("click", function() {
            var dark = document.documentElement.classList.toggle("dark");
            localStorage.setItem("theme", dark ? "dark" : "light");
            var s = document.getElementById("sun-icon");
            var m = document.getElementById("moon-icon");
            if (s) s.classList.toggle("hidden", dark);
            if (m) m.classList.toggle("hidden", !dark);
          });
        }
      }
      setupTheme();
      document.addEventListener("astro:after-swap", setupTheme);
    </script>
  </body>
</html>
