---
import { ClientRouter } from "astro:transitions";
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "LPR Dataset Hub",
  description = "ALL-IN-ONE gateway for License Plate Recognition datasets. Discover, compare, and access 15+ datasets across 10+ countries.",
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />

    <title>{title}</title>
    <ClientRouter />
  </head>
  <body class="min-h-screen flex flex-col">
    <!-- Navigation -->
    <nav class="sticky top-0 z-50 border-b border-[rgb(var(--card-border))] bg-[rgb(var(--bg))]/80 backdrop-blur-md">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-14">
          <a href="/" class="flex items-center gap-2 font-semibold text-lg hover:text-[rgb(var(--accent))] transition-colors">
            <span class="text-xl">🚗</span>
            <span>LPR Dataset Hub</span>
          </a>
          <div class="flex items-center gap-4">
            <a href="/" class="text-sm font-medium text-[rgb(var(--muted))] hover:text-[rgb(var(--fg))] transition-colors">
              Catalog
            </a>
            <a href="/leaderboard" class="text-sm font-medium text-[rgb(var(--muted))] hover:text-[rgb(var(--fg))] transition-colors">
              Leaderboard
            </a>
            <a
              href="https://github.com/Kein95/luonvuituoi-lpr-datahub"
              target="_blank"
              rel="noopener"
              class="text-sm font-medium text-[rgb(var(--muted))] hover:text-[rgb(var(--fg))] transition-colors"
            >
              GitHub
            </a>
            <button
              id="theme-toggle"
              class="p-2 rounded-lg text-[rgb(var(--muted))] hover:text-[rgb(var(--fg))] hover:bg-[rgb(var(--card))] transition-colors"
              aria-label="Toggle theme"
            >
              <svg id="sun-icon" class="w-4 h-4 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="5" /><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
              </svg>
              <svg id="moon-icon" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z" />
              </svg>
            </button>
          </div>
        </div>
      </div>
    </nav>

    <!-- Main Content -->
    <main class="flex-1">
      <slot />
    </main>

    <!-- Footer -->
    <footer class="border-t border-[rgb(var(--card-border))] py-8 mt-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center text-sm text-[rgb(var(--muted))]">
        <p class="mb-2">
          <strong>LPR Dataset Hub</strong> — ALL-IN-ONE gateway for License Plate Recognition research
        </p>
        <p class="mb-2">
          A project by
          <a href="https://aivietnam.edu.vn/" target="_blank" rel="noopener" class="text-[rgb(var(--accent))] hover:underline">AI VIET NAM (AIO) Lab</a>
          <span class="mx-1">·</span>
          TA: <a href="https://github.com/duongtruongbinh" target="_blank" rel="noopener" class="hover:text-[rgb(var(--accent))] transition-colors">Truong-Binh Duong</a>
          <span class="mx-1">·</span>
          Contact: <a href="mailto:htkien95@gmail.com" class="hover:text-[rgb(var(--accent))] transition-colors">htkien95@gmail.com</a>
        </p>
        <p>
          <a href="https://aioconquer.aivietnam.edu.vn/" target="_blank" rel="noopener" class="hover:text-[rgb(var(--accent))] transition-colors">Blog</a>
          <span class="mx-1">·</span>
          <a href="https://www.facebook.com/aivietnam.edu.vn" target="_blank" rel="noopener" class="hover:text-[rgb(var(--accent))] transition-colors">Facebook</a>
          <span class="mx-1">·</span>
          <a href="https://github.com/Kein95/luonvuituoi-lpr-datahub" target="_blank" rel="noopener" class="hover:text-[rgb(var(--accent))] transition-colors">Contribute via PR</a>
          <span class="mx-1">·</span>
          Built with <a href="https://astro.build" target="_blank" rel="noopener" class="hover:text-[rgb(var(--accent))] transition-colors">Astro</a>
        </p>
      </div>
    </footer>

    <!-- Theme Toggle Script -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem("theme");
        const prefersDark = window.matchMedia("(prefers-color-scheme: dark)").matches;
        const isDark = stored === "dark" || (!stored && prefersDark);
        document.documentElement.classList.toggle("dark", isDark);
        updateIcons(isDark);

        document.getElementById("theme-toggle")?.addEventListener("click", () => {
          const dark = document.documentElement.classList.toggle("dark");
          localStorage.setItem("theme", dark ? "dark" : "light");
          updateIcons(dark);
        });

        function updateIcons(dark) {
          document.getElementById("sun-icon")?.classList.toggle("hidden", dark);
          document.getElementById("moon-icon")?.classList.toggle("hidden", !dark);
        }
      })();
    </script>
  </body>
</html>
