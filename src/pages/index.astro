---
import Base from "@/layouts/base.astro";
import DatasetCatalog from "@/components/dataset-catalog";
import { getCollection } from "astro:content";

const allDatasets = await getCollection("datasets");

// Transform to catalog format
const datasets = allDatasets.map((entry) => ({
  id: entry.id,
  ...entry.data,
}));

// Stats
const totalDatasets = datasets.length;
const countries = new Set(datasets.map((d) => d.country));
const publicCount = datasets.filter((d) => d.access === "public").length;
const multiFrameCount = datasets.filter((d) => d.frames.includes("multi")).length;
---

<Base title="LPR Dataset Hub — ALL-IN-ONE Gateway for LPR Research">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-br from-[rgb(var(--accent))]/5 to-transparent pointer-events-none"></div>
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16 sm:py-20">
      <div class="text-center max-w-3xl mx-auto">
        <h1 class="text-4xl sm:text-5xl font-bold tracking-tight mb-4">
          LPR Dataset
          <span class="text-[rgb(var(--accent))]">Hub</span>
        </h1>
        <p class="text-lg text-[rgb(var(--muted))] mb-8 max-w-2xl mx-auto">
          ALL-IN-ONE gateway for License Plate Recognition research.
          Discover, compare, and access datasets across {countries.size}+ countries.
        </p>

        <!-- Stat Cards -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 max-w-2xl mx-auto mb-12">
          <div class="rounded-xl border border-[rgb(var(--card-border))] bg-[rgb(var(--card))] p-4">
            <div class="text-2xl font-bold font-mono text-[rgb(var(--accent))]">{totalDatasets}</div>
            <div class="text-xs text-[rgb(var(--muted))] mt-1">Datasets</div>
          </div>
          <div class="rounded-xl border border-[rgb(var(--card-border))] bg-[rgb(var(--card))] p-4">
            <div class="text-2xl font-bold font-mono text-[rgb(var(--accent))]">{countries.size}</div>
            <div class="text-xs text-[rgb(var(--muted))] mt-1">Countries</div>
          </div>
          <div class="rounded-xl border border-[rgb(var(--card-border))] bg-[rgb(var(--card))] p-4">
            <div class="text-2xl font-bold font-mono text-[rgb(var(--accent))]">{publicCount}</div>
            <div class="text-xs text-[rgb(var(--muted))] mt-1">Public</div>
          </div>
          <div class="rounded-xl border border-[rgb(var(--card-border))] bg-[rgb(var(--card))] p-4">
            <div class="text-2xl font-bold font-mono text-[rgb(var(--accent))]">{multiFrameCount}</div>
            <div class="text-xs text-[rgb(var(--muted))] mt-1">Multi-Frame</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Dataset Catalog -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <DatasetCatalog client:load datasets={datasets} />
  </section>
</Base>
