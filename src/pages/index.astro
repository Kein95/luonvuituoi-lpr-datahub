---
import Base from "@/layouts/base.astro";
import DatasetCatalog from "@/components/dataset-catalog";
import { getCollection } from "astro:content";

const allDatasets = await getCollection("datasets");

const datasets = allDatasets.map((entry) => ({
  id: entry.id,
  ...entry.data,
}));

const totalDatasets = datasets.length;
const countries = new Set(datasets.map((d) => d.country));
const publicCount = datasets.filter((d) => d.access === "public").length;
const multiFrameCount = datasets.filter((d) => d.frames.toLowerCase().includes("multi")).length;
---

<Base title="LPR Dataset Hub - ALL-IN-ONE Gateway for LPR Research">
  <!-- Hero Section -->
  <section class="relative overflow-hidden">
    <div class="absolute inset-0 hero-gradient-bg pointer-events-none"></div>
    <div class="absolute inset-0 dot-pattern pointer-events-none opacity-30 dark:opacity-20"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 sm:py-28">
      <div class="text-center max-w-3xl mx-auto">
        <!-- Status Badge -->
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full border border-[rgb(var(--card-border))] bg-[rgb(var(--card))]/80 backdrop-blur-sm text-xs font-medium text-[rgb(var(--muted))] mb-6 animate-fade-in">
          <span class="w-1.5 h-1.5 rounded-full bg-[rgb(var(--public))] animate-pulse"></span>
          Open Research Resource &middot; {totalDatasets} Datasets Indexed
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-bold tracking-tight mb-5 text-balance animate-slide-up">
          The Dataset Hub for
          <span class="gradient-text">License Plate Recognition</span>
        </h1>
        <p class="text-lg sm:text-xl text-[rgb(var(--muted))] mb-10 max-w-2xl mx-auto leading-relaxed animate-slide-up" style="animation-delay: 100ms">
          Discover, compare, and access {totalDatasets} datasets across {countries.size}+ countries.
          <br />Built for researchers, by researchers.
        </p>

        <!-- Acknowledgments + Links -->
        <div class="mb-10 animate-slide-up" style="animation-delay: 150ms">
          <p class="text-sm text-[rgb(var(--muted))] mb-4">
            Special thanks to the <a href="https://aivietnam.edu.vn/" target="_blank" rel="noopener" class="text-[rgb(var(--accent))] hover:underline font-semibold">AI VIET NAM (AIO)</a> community
            and TA <a href="https://github.com/duongtruongbinh" target="_blank" rel="noopener" class="text-[rgb(var(--accent))] hover:underline font-semibold">Truong-Binh Duong</a>
          </p>
          <div class="flex flex-wrap justify-center gap-2">
            <a href="https://aivietnam.edu.vn/" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg bg-[rgb(var(--accent))]/10 border border-[rgb(var(--accent))]/20 text-[rgb(var(--accent))] text-sm font-semibold hover:bg-[rgb(var(--accent))]/20 transition-all">
              🎓 Learn AI
            </a>
            <a href="https://aioconquer.aivietnam.edu.vn/" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-[rgb(var(--card-border))] text-[rgb(var(--fg))] text-sm font-medium hover:border-[rgb(var(--accent))]/50 hover:text-[rgb(var(--accent))] transition-all">
              📝 Blog
            </a>
            <a href="https://www.facebook.com/aivietnam.edu.vn" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-[rgb(var(--card-border))] text-[rgb(var(--fg))] text-sm font-medium hover:border-[rgb(var(--accent))]/50 hover:text-[rgb(var(--accent))] transition-all">
              💬 Facebook
            </a>
            <a href="https://github.com/Kein95/luonvuituoi-lpr-datahub" target="_blank" rel="noopener" class="inline-flex items-center gap-1.5 px-4 py-2 rounded-lg border border-[rgb(var(--accent))]/30 text-[rgb(var(--accent))] text-sm font-semibold hover:bg-[rgb(var(--accent))]/10 transition-all">
              ⭐ Contribute via PR
            </a>
          </div>
        </div>

        <!-- Stat Cards -->
        <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 max-w-2xl mx-auto mb-4 animate-slide-up" style="animation-delay: 200ms">
          <div class="stat-card">
            <div class="text-2xl sm:text-3xl font-bold font-mono gradient-text">{totalDatasets}</div>
            <div class="text-xs text-[rgb(var(--muted))] mt-1.5 font-medium uppercase tracking-wider">Datasets</div>
          </div>
          <div class="stat-card">
            <div class="text-2xl sm:text-3xl font-bold font-mono gradient-text">{countries.size}</div>
            <div class="text-xs text-[rgb(var(--muted))] mt-1.5 font-medium uppercase tracking-wider">Countries</div>
          </div>
          <div class="stat-card">
            <div class="text-2xl sm:text-3xl font-bold font-mono gradient-text">{publicCount}</div>
            <div class="text-xs text-[rgb(var(--muted))] mt-1.5 font-medium uppercase tracking-wider">Public</div>
          </div>
          <div class="stat-card">
            <div class="text-2xl sm:text-3xl font-bold font-mono gradient-text">{multiFrameCount}</div>
            <div class="text-xs text-[rgb(var(--muted))] mt-1.5 font-medium uppercase tracking-wider">Multi-Frame</div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Access Levels -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mb-8">
    <div class="flex flex-wrap justify-center gap-4 text-sm">
      <div class="flex items-center gap-2">
        <span class="badge bg-[rgb(var(--public))]/10 text-[rgb(var(--public))] border border-[rgb(var(--public))]/20">Public</span>
        <span class="text-[rgb(var(--muted))]">Free download</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="badge bg-[rgb(var(--license))]/10 text-[rgb(var(--license))] border border-[rgb(var(--license))]/20">License</span>
        <span class="text-[rgb(var(--muted))]">Agreement required</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="badge bg-[rgb(var(--license))]/10 text-[rgb(var(--license))] border border-[rgb(var(--license))]/20">.edu</span>
        <span class="text-[rgb(var(--muted))]">.edu email required</span>
      </div>
      <div class="flex items-center gap-2">
        <span class="badge bg-[rgb(var(--staff))]/10 text-[rgb(var(--staff))] border border-[rgb(var(--staff))]/20">Staff</span>
        <span class="text-[rgb(var(--muted))]">University staff only</span>
      </div>
    </div>
  </section>

  <!-- Dataset Catalog -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 pb-16">
    <DatasetCatalog client:load datasets={datasets} />
  </section>
</Base>
