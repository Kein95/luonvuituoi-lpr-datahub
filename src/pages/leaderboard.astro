---
import Base from "@/layouts/base.astro";
import SotaTable from "@/components/sota-table";
import { getCollection } from "astro:content";

let sotaData: any[] = [];
try {
  const sotaCollection = await getCollection("sota");
  sotaData = sotaCollection.map((entry) => ({
    id: entry.id,
    ...entry.data,
  }));
} catch { /* no SOTA data yet */ }
---

<Base title="SOTA Leaderboard - LPR Dataset Hub" description="Published state-of-the-art results for License Plate Recognition datasets.">
  <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Header -->
    <div class="mb-8 text-center">
      <div class="inline-flex items-center gap-2 mb-4">
        <h1 class="text-3xl font-bold tracking-tight">SOTA Leaderboard</h1>
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-[rgb(var(--accent))]/10 text-[rgb(var(--accent))] text-xs font-bold uppercase tracking-wider">
          <span class="w-1.5 h-1.5 rounded-full bg-[rgb(var(--accent))] animate-pulse"></span>
          In Progress
        </span>
      </div>
      <p class="text-[rgb(var(--muted))]">
        Published results from peer-reviewed papers. Compare methods across datasets.
      </p>
    </div>

    <!-- Status Banner -->
    <div class="relative overflow-hidden rounded-2xl border border-[rgb(var(--accent))]/20 bg-gradient-to-br from-[rgb(var(--accent))]/5 via-[rgb(var(--card))] to-[rgb(var(--gradient-to))]/5 p-8 sm:p-12 text-center mb-8">
      <div class="absolute inset-0 dot-pattern opacity-20 pointer-events-none"></div>
      <div class="relative">
        <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-[rgb(var(--accent))]/10 mb-5">
          <svg class="w-8 h-8 text-[rgb(var(--accent))]" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
            <path d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/>
          </svg>
        </div>
        <h2 class="text-2xl font-bold mb-3 tracking-tight">Leaderboard Coming Soon</h2>
        <p class="text-[rgb(var(--muted))] max-w-lg mx-auto mb-6 leading-relaxed">
          We're collecting and verifying SOTA results from published papers across all datasets.
          Contribute your results to help build the community benchmark.
        </p>
        <a
          href="https://github.com/Kein95/luonvuituoi-lpr-datahub"
          target="_blank"
          rel="noopener"
          class="inline-flex items-center gap-2 px-6 py-3 rounded-xl bg-[rgb(var(--accent))] text-white font-semibold hover:shadow-glow-lg hover:brightness-110 transition-all duration-300"
        >
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          Submit Results via PR
        </a>
      </div>
    </div>

    <!-- How to Submit - Step by Step -->
    <div class="stat-card mb-8">
      <h3 class="text-lg font-semibold mb-4">How to Submit Results</h3>
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-6">
        <!-- Step 1 -->
        <div>
          <div class="flex items-center gap-2 mb-2">
            <span class="flex items-center justify-center w-7 h-7 rounded-full bg-[rgb(var(--accent))]/10 text-[rgb(var(--accent))] text-sm font-bold">1</span>
            <span class="font-medium">Fork & Create File</span>
          </div>
          <p class="text-sm text-[rgb(var(--muted))] ml-9">
            Fork <a href="https://github.com/Kein95/luonvuituoi-lpr-datahub" target="_blank" rel="noopener" class="text-[rgb(var(--accent))] hover:underline">the repo</a>, create a JSON file at <code class="text-xs bg-[rgb(var(--bg-subtle))] px-1 py-0.5 rounded">src/content/sota/&#123;dataset-id&#125;.json</code>
          </p>
        </div>
        <!-- Step 2 -->
        <div>
          <div class="flex items-center gap-2 mb-2">
            <span class="flex items-center justify-center w-7 h-7 rounded-full bg-[rgb(var(--accent))]/10 text-[rgb(var(--accent))] text-sm font-bold">2</span>
            <span class="font-medium">Fill in Results</span>
          </div>
          <p class="text-sm text-[rgb(var(--muted))] ml-9">
            Method name, paper, venue, year, accuracy (%). Code URL optional but encouraged.
          </p>
        </div>
        <!-- Step 3 -->
        <div>
          <div class="flex items-center gap-2 mb-2">
            <span class="flex items-center justify-center w-7 h-7 rounded-full bg-[rgb(var(--accent))]/10 text-[rgb(var(--accent))] text-sm font-bold">3</span>
            <span class="font-medium">Submit PR</span>
          </div>
          <p class="text-sm text-[rgb(var(--muted))] ml-9">
            Submit Pull Request to <code class="text-xs bg-[rgb(var(--bg-subtle))] px-1 py-0.5 rounded">dev</code> branch. We'll review and merge.
          </p>
        </div>
      </div>
      <!-- JSON Template -->
      <details class="mt-6">
        <summary class="cursor-pointer text-sm font-medium text-[rgb(var(--accent))] hover:underline">View JSON Template</summary>
        <div class="mt-3 rounded-xl border border-[rgb(var(--card-border))] overflow-hidden">
          <div class="flex items-center justify-between px-4 py-2 border-b border-[rgb(var(--card-border))]/50 bg-[rgb(var(--card))]/80">
            <span class="text-xs font-mono text-[rgb(var(--muted))]">src/content/sota/ccpd-2019.json</span>
          </div>
          <pre class="text-xs font-mono text-[rgb(var(--muted))] p-4 overflow-x-auto whitespace-pre-wrap leading-relaxed bg-[rgb(var(--bg-subtle))]">&#123;
  "dataset_id": "ccpd-2019",
  "metric": "sequence_accuracy",
  "metric_label": "Sequence Accuracy (%)",
  "results": [
    &#123;
      "method": "Your Method",
      "paper": "Paper Title",
      "venue": "ECCV 2025",
      "year": 2025,
      "accuracy": 95.5,
      "params_m": 12.3,
      "code_url": "https://github.com/...",
      "notes": "Optional note"
    &#125;
  ]
&#125;</pre>
        </div>
      </details>
    </div>

    {sotaData.length > 0 && (
      <SotaTable client:load sotaData={sotaData} />
    )}
  </div>
</Base>
