---
import Base from "@/layouts/base.astro";
import { getCollection } from "astro:content";
import { getFlag } from "@/lib/utils";

export async function getStaticPaths() {
  const datasets = await getCollection("datasets");
  return datasets.map((entry) => ({
    params: { id: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const d = entry.data;
const flag = getFlag(d.country);

const accessStyles: Record<string, { label: string; cls: string }> = {
  public: { label: "Public", cls: "bg-[rgb(var(--public))]/10 text-[rgb(var(--public))] border border-[rgb(var(--public))]/20" },
  license: { label: "License Required", cls: "bg-[rgb(var(--license))]/10 text-[rgb(var(--license))] border border-[rgb(var(--license))]/20" },
  "license-edu": { label: ".edu Email Required", cls: "bg-[rgb(var(--license))]/10 text-[rgb(var(--license))] border border-[rgb(var(--license))]/20" },
  "license-staff": { label: "Staff Only", cls: "bg-[rgb(var(--staff))]/10 text-[rgb(var(--staff))] border border-[rgb(var(--staff))]/20" },
};

const badge = accessStyles[d.access] || accessStyles.license;

const allDatasets = await getCollection("datasets");
const related = allDatasets
  .filter((other) => other.id !== entry.id && (other.data.country === d.country || other.data.task === d.task))
  .slice(0, 4);

let sotaResults: any[] = [];
try {
  const sotaCollection = await getCollection("sota");
  const sotaEntry = sotaCollection.find((s) => s.data.dataset_id === entry.id);
  if (sotaEntry) {
    sotaResults = sotaEntry.data.results.sort((a, b) => b.accuracy - a.accuracy).slice(0, 5);
  }
} catch { /* no SOTA data yet */ }
---

<Base title={`${d.name} — LPR Dataset Hub`} description={d.description || d.notes || `${d.name} dataset for license plate recognition`}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Breadcrumb -->
    <a href="/" class="inline-flex items-center gap-1 text-sm text-[rgb(var(--muted))] hover:text-[rgb(var(--accent))] transition-colors mb-6" data-astro-prefetch>
      ← Back to Catalog
    </a>

    <!-- Header Card -->
    <div class="relative overflow-hidden rounded-2xl border border-[rgb(var(--card-border))] bg-[rgb(var(--card))] p-6 sm:p-8 mb-8">
      <div class="absolute inset-0 hero-gradient-bg opacity-30 pointer-events-none"></div>
      <div class="relative">
        <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4">
          <div>
            <h1 class="text-3xl sm:text-4xl font-bold mb-2 tracking-tight">
              <span class="mr-2">{flag}</span>{d.name}
            </h1>
            <p class="text-[rgb(var(--muted))] flex items-center gap-2 flex-wrap">
              <span>{d.task}</span>
              <span class="text-[rgb(var(--card-border))]">&middot;</span>
              <span>{d.country}</span>
              <span class="text-[rgb(var(--card-border))]">&middot;</span>
              <span>{d.year}</span>
            </p>
          </div>
          <span class={`badge text-sm whitespace-nowrap ${badge.cls}`}>
            {badge.label}
          </span>
        </div>
      </div>
    </div>

    <!-- Stats Grid -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 mb-8">
      <div class="stat-card">
        <div class="text-xs text-[rgb(var(--muted))] font-medium uppercase tracking-wider mb-2">Images</div>
        <div class="text-xl font-bold font-mono">{d.size || "—"}</div>
      </div>
      <div class="stat-card">
        <div class="text-xs text-[rgb(var(--muted))] font-medium uppercase tracking-wider mb-2">Frame Type</div>
        <div class="text-xl font-bold font-mono capitalize">{d.frames}</div>
      </div>
      <div class="stat-card">
        <div class="text-xs text-[rgb(var(--muted))] font-medium uppercase tracking-wider mb-2">Classes</div>
        <div class="text-xl font-bold font-mono">{d.classes || "—"}</div>
      </div>
      <div class="stat-card">
        <div class="text-xs text-[rgb(var(--muted))] font-medium uppercase tracking-wider mb-2">Annotation</div>
        <div class="text-sm font-semibold">{d.annotation}</div>
      </div>
    </div>

    <!-- Description -->
    <section class="mb-8">
      <h2 class="text-lg font-semibold mb-3">Description</h2>
      <p class="text-[rgb(var(--muted))] leading-relaxed">
        {d.description || d.notes || "No description available."}
      </p>
      {d.resolution && (
        <p class="text-sm text-[rgb(var(--muted))] mt-2">
          <span class="font-medium text-[rgb(var(--fg))]">Resolution:</span> {d.resolution}
        </p>
      )}
      {d.license_type && (
        <p class="text-sm text-[rgb(var(--muted))] mt-1">
          <span class="font-medium text-[rgb(var(--fg))]">License:</span> {d.license_type}
        </p>
      )}
    </section>

    <!-- Access / Download Links -->
    <section class="mb-8">
      <h2 class="text-lg font-semibold mb-3">Access</h2>
      <div class="flex flex-wrap gap-3">
        {d.source_url && (
          <a
            href={d.source_url}
            target="_blank"
            rel="noopener"
            class="outbound-link inline-flex items-center gap-2 px-5 py-2.5 rounded-xl bg-[rgb(var(--accent))] text-white text-sm font-semibold hover:shadow-glow hover:brightness-110 transition-all duration-300"
            data-dataset={d.name}
            data-type="source"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
            Source Repository
          </a>
        )}
        {d.paper_url && (
          <a
            href={d.paper_url}
            target="_blank"
            rel="noopener"
            class="outbound-link inline-flex items-center gap-2 px-5 py-2.5 rounded-xl border border-[rgb(var(--card-border))] text-[rgb(var(--fg))] text-sm font-medium hover:border-[rgb(var(--accent))]/50 hover:text-[rgb(var(--accent))] transition-all"
            data-dataset={d.name}
            data-type="paper"
          >
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253"/></svg>
            Paper
          </a>
        )}
      </div>
    </section>

    <!-- BibTeX Citation -->
    {d.bibtex && (
      <section class="mb-8">
        <h2 class="text-lg font-semibold mb-3">Citation</h2>
        <div class="relative rounded-xl border border-[rgb(var(--card-border))] overflow-hidden">
          <div class="flex items-center justify-between px-4 py-2 border-b border-[rgb(var(--card-border))]/50 bg-[rgb(var(--card))]/80">
            <span class="text-xs font-mono text-[rgb(var(--muted))]">BibTeX</span>
            <button
              id="copy-bibtex"
              class="inline-flex items-center gap-1.5 px-3 py-1 text-xs font-medium rounded-md text-[rgb(var(--muted))] hover:text-[rgb(var(--fg))] hover:bg-[rgb(var(--card-border))]/30 transition-all"
            >
              <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"/></svg>
              Copy
            </button>
          </div>
          <pre class="text-xs font-mono text-[rgb(var(--muted))] p-4 overflow-x-auto whitespace-pre-wrap leading-relaxed bg-[rgb(var(--bg-subtle))]" id="bibtex-content">{d.bibtex}</pre>
        </div>
      </section>
    )}

    <!-- SOTA Preview -->
    {sotaResults.length > 0 && (
      <section class="mb-8">
        <div class="flex items-center justify-between mb-3">
          <h2 class="text-lg font-semibold">SOTA Results</h2>
          <a href="/leaderboard" class="text-sm text-[rgb(var(--accent))] hover:underline" data-astro-prefetch>
            View Full Leaderboard →
          </a>
        </div>
        <div class="overflow-x-auto rounded-xl border border-[rgb(var(--card-border))]">
          <table class="w-full text-sm">
            <thead>
              <tr class="bg-[rgb(var(--bg-subtle))] border-b border-[rgb(var(--card-border))]">
                <th class="px-4 py-2 text-left text-xs font-semibold text-[rgb(var(--muted))]">#</th>
                <th class="px-4 py-2 text-left text-xs font-semibold text-[rgb(var(--muted))]">Method</th>
                <th class="px-4 py-2 text-left text-xs font-semibold text-[rgb(var(--muted))]">Venue</th>
                <th class="px-4 py-2 text-right text-xs font-semibold text-[rgb(var(--muted))]">Accuracy</th>
              </tr>
            </thead>
            <tbody>
              {sotaResults.map((r, i) => (
                <tr class="border-b border-[rgb(var(--card-border))]/60">
                  <td class="px-4 py-2 font-mono text-xs">{i === 0 ? "🥇" : i === 1 ? "🥈" : i === 2 ? "🥉" : i + 1}</td>
                  <td class="px-4 py-2 font-medium">{r.method}</td>
                  <td class="px-4 py-2 text-[rgb(var(--muted))]">{r.venue}</td>
                  <td class="px-4 py-2 text-right font-mono font-semibold">{r.accuracy.toFixed(1)}%</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}

    <!-- Related Datasets -->
    {related.length > 0 && (
      <section class="mb-8">
        <h2 class="text-lg font-semibold mb-3">Related Datasets</h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
          {related.map((r) => (
            <a
              href={`/datasets/${r.id}`}
              class="card-glow rounded-xl border border-[rgb(var(--card-border))] bg-[rgb(var(--card))] p-5 hover:border-[rgb(var(--accent))]/30 hover:shadow-glow transition-all duration-300 block group"
              data-astro-prefetch
            >
              <div class="font-semibold mb-1.5 group-hover:text-[rgb(var(--accent))] transition-colors">{getFlag(r.data.country)} {r.data.name}</div>
              <div class="text-xs text-[rgb(var(--muted))] flex items-center gap-2">
                <span>{r.data.country}</span>
                <span class="text-[rgb(var(--card-border))]">&middot;</span>
                <span class="font-mono">{r.data.size}</span>
                <span class="text-[rgb(var(--card-border))]">&middot;</span>
                <span class="font-mono">{r.data.year}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}
  </div>

  <!-- Scripts -->
  <script is:inline>
    document.getElementById("copy-bibtex")?.addEventListener("click", function () {
      var text = document.getElementById("bibtex-content")?.textContent;
      if (text) {
        navigator.clipboard.writeText(text).then(() => {
          this.textContent = "Copied!";
          var btn = this;
          setTimeout(function() { btn.textContent = "Copy"; }, 2000);
        });
      }
    });

    document.querySelectorAll(".outbound-link").forEach(function(link) {
      link.addEventListener("click", function () {
        try {
          var dataset = this.getAttribute("data-dataset");
          var type = this.getAttribute("data-type");
          var url = this.href;
          var clicks = JSON.parse(localStorage.getItem("lpr_clicks") || "[]");
          clicks.push({ dataset: dataset, type: type, url: url, time: Date.now() });
          if (clicks.length > 500) clicks.splice(0, clicks.length - 500);
          localStorage.setItem("lpr_clicks", JSON.stringify(clicks));
        } catch (e) { /* silent */ }
      });
    });
  </script>
</Base>
